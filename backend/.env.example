# ───────────────────────────────────────────────────────────────
# BetterTrack AI — Backend environment
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ───────────────────────────────────────────────────────────────

# ── App ──
APP_NAME=BetterTrack AI
ENVIRONMENT=development          # development | production
HOST=0.0.0.0
PORT=8000
# Comma-separated origins allowed to call the API (Flutter dev, web, etc.)
CORS_ORIGINS=*

# ── AI Assistant ──
# AI_PROVIDER: gemini | anthropic
AI_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Anthropic Claude (alternative provider)
ANTHROPIC_API_KEY=
AI_MODEL=claude-fable-5

# ── Receipt OCR ──
# OCR_PROVIDER options: tesseract (local, no key) | google | mindee | textract
OCR_PROVIDER=tesseract
# Only needed if OCR_PROVIDER is a cloud service:
OCR_API_KEY=

# ── Database ──
# Default is a local SQLite file; swap for Postgres in production.
DATABASE_URL=sqlite:///./bettertrack.db

# ── Obsidian (Semantic Notes Vault MCP) ──
# The plugin's HTTP server. Port + API key come from the plugin settings
# (.obsidian/plugins/semantic-vault-mcp/data.json).
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=3001
OBSIDIAN_API_KEY=
# Absolute path to the vault, used by graphifyy for direct file sync.
OBSIDIAN_VAULT_PATH=/Users/lalitsingh/WORKS/Split-wise

# ── Security ──
# Used to sign JWTs once auth is added. Generate: openssl rand -hex 32
SECRET_KEY=
