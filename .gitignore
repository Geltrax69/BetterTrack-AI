# ── Secrets (NEVER commit) ──
**/.env
backend/.env
*.key
*.pem

# ── Obsidian vault config (contains the local MCP API key) ──
.obsidian/

# ── Python / backend ──
backend/.venv/
**/__pycache__/
*.py[cod]
backend/*.db
backend/bettertrack.db

# graphify output (regenerable knowledge graph)
graphify-out/
backend/graphify-out/

# ── Flutter / Dart ──
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/build/
app/.idea/
app/*.iml

# iOS / CocoaPods build artifacts
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/ios/Flutter/ephemeral/

# Android
app/android/.gradle/
app/android/local.properties
app/android/key.properties

# ── macOS / editors ──
.DS_Store
*.swp

# Remember plugin session buffer (local only)
.remember/
